{
  "name": "reqspec",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "docs",
    "frontend",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "check-types": "turbo check-types",
    "commit": "git add . && bun committier ai",
    "dev": "turbo dev",
    "format": "bun format:biome .",
    "format:biome": "bunx biome check --diagnostic-level=error --write --unsafe",
    "prepare": "lefthook install || true",
    "start": "turbo start"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@commitlint/types": "^20.5.0",
    "@hyoretsu/configs": "^1.2.33",
    "@types/bun": "^1.3.13",
    "committier": "^0.2.3",
    "lefthook": "^2.1.8",
    "turbo": "^2.9.7",
    "typescript": "^6.0.3"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "esbuild",
    "lefthook"
  ]
}
