{
	"$schema": "https://turborepo.dev/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^export", "generate"],
			"inputs": ["src/**", "!src/**/generated/**"],
			"outputLogs": "new-only",
			"outputs": ["build/**", "dist/**", "out/**", ".next/**", "!.next/cache/**"]
		},
		"check-types": {
			"dependsOn": ["^export", "generate"],
			"inputs": ["src/**", "tsconfig*.json"],
			"outputLogs": "new-only"
		},
		"dev": {
			"cache": false,
			"dependsOn": ["^export", "generate"],
			"persistent": true
		},
		"export": {
			"dependsOn": ["^export", "generate"],
			"env": ["DATABASE_URL"],
			"inputs": ["src/**", "!src/**/generated/**"],
			"outputLogs": "new-only",
			"outputs": ["out/**"]
		},
		"frontend#generate": {
			"dependsOn": ["^export"],
			"inputs": ["kubb.config.ts"],
			"outputLogs": "new-only",
			"outputs": ["src/lib/api/generated/**"]
		},
		"generate": {
			"dependsOn": ["^export"],
			"env": ["DATABASE_URL"],
			"inputs": ["src/**", "!src/generated/**"],
			"outputLogs": "new-only",
			"outputs": ["src/generated/**"]
		},
		"migrate:deploy": {
			"env": ["DATABASE_URL", "DATABASE_TEST_URL"],
			"inputs": ["src/migrations/**"],
			"outputLogs": "new-only"
		},
		"start": {
			"cache": false
		},
		"test": {
			"dependsOn": ["test:unit", "test:e2e"]
		},
		"test:e2e": {
			"cache": false,
			"dependsOn": ["^export"],
			"env": ["DATABASE_TEST_URL", "DATABASE_URL"]
		},
		"test:unit": {
			"dependsOn": ["^export"],
			"inputs": ["**/*.test.ts", "!**/*.e2e.test.ts"],
			"outputLogs": "new-only"
		}
	}
}
